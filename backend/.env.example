# STBank LeadGen Backend Environment Configuration
# Copy this file to .env and fill in your values

# App Configuration
APP_NAME=STBank LeadGen API
APP_VERSION=1.0.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql://stbank:password@localhost:5432/stbank_leadgen
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (Optional)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS
CORS_ORIGINS=["https://lead.stbank.la","http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Email/SMS (Optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=STBank <noreply@stbank.la>

# Core Banking Integration (Optional)
# CORE_BANKING_URL=https://core-banking.example.com/api
# CORE_BANKING_API_KEY=your-api-key

# LDAP/AD Integration (Optional - for on-premise)
LDAP_ENABLED=false
# LDAP_SERVER=ldap://192.168.1.100
# LDAP_BASE_DN=dc=stbank,dc=la
# LDAP_BIND_DN=cn=admin,dc=stbank,dc=la
# LDAP_BIND_PASSWORD=your-ldap-password
LDAP_USE_SSL=true

# WhatsApp Business (Optional)
WHATSAPP_ENABLED=false
# WHATSAPP_API_URL=https://api.whatsapp.com
# WHATSAPP_TOKEN=your-whatsapp-token

# LINE Messaging (Optional)
LINE_ENABLED=false
# LINE_CHANNEL_ID=your-channel-id
# LINE_CHANNEL_SECRET=your-channel-secret
# LINE_ACCESS_TOKEN=your-access-token

# Ollama AI (Optional - for on-premise AI)
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
AI_SCORING_ENABLED=false
AI_CHATBOT_ENABLED=false
AI_ANALYTICS_ENABLED=false

# Compliance & Data Residency (Laos)
DATA_RESIDENCY_COUNTRY=Laos
AUDIT_RETENTION_YEARS=7
ANONYMIZATION_RETENTION_DAYS=90